# ============================================================
# CrewAI + CockroachDB PoC — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER commit your .env file to Git!

# ── LLM Provider ────────────────────────────────────────────
# OpenAI Platform API Key
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_key_here

# (Optional) Override the default model
# OPENAI_MODEL_NAME=gpt-4o-mini

# ── CockroachDB ─────────────────────────────────────────────
# Connection string from CockroachDB Cloud console
# Format: postgresql://username:password@host:port/database?sslmode=verify-full
COCKROACHDB_URL=postgresql://username:password@your-cluster.cockroachdb.com:26257/defaultdb?sslmode=verify-full

# ── Optional: Ollama (local LLM, no API key needed) ─────────
# Uncomment these if using Ollama instead of OpenAI
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL_NAME=llama3.1
